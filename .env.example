# ============================================================
# Track.fun — Environment variables
# Copy this file to `.env.local` and fill in the values.
# Do NOT commit `.env.local`.
# ============================================================

# -------- Database (Supabase) — REQUIRED --------
# From Supabase dashboard: Settings → Database → Connection string
# DATABASE_URL = Transaction mode pooler (for app runtime, includes ?pgbouncer=true)
# DIRECT_URL   = Session mode direct (for migrations)
DATABASE_URL=postgresql://postgres.xxx:[PW]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxx:[PW]@aws-0-us-east-1.pooler.supabase.com:5432/postgres


# -------- Cron secret — REQUIRED --------
# Generate with: openssl rand -hex 32
# Vercel Cron sends this as `Authorization: Bearer <secret>`.
# Without this, the cron endpoint fails closed (returns 401).
CRON_SECRET=


# -------- Privy Auth (required) --------
# Get these from https://dashboard.privy.io/
# App ID is public and safe to expose to the browser.
NEXT_PUBLIC_PRIVY_APP_ID=

# Client ID is required for some Privy features (e.g. self-hosted / embedded wallets).
# Leave blank if your Privy app doesn't require it.
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Privy App Secret — SERVER-SIDE ONLY.
# Used by @privy-io/server-auth to verify access tokens on API routes.
# Never expose this to the client.
PRIVY_APP_SECRET=


# -------- Polymarket (optional) --------
# The Gamma API is public and requires no key.
# You can override the base URL if Polymarket changes it.
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# How often the client re-fetches markets (ms). Default 30s.
NEXT_PUBLIC_POLYMARKET_REFRESH_MS=30000


# -------- Simulated Execution (server-side, not user-visible) --------
# Spread applied to every simulated bot fill, in absolute price cents
# (prediction markets trade on a 0–1 scale, so "cents" means $0.01).
#
# 0.01  = 1c per side       (~2c round-trip) — default
# 0.005 = 0.5c per side
# 0.02  = 2c per side       (more aggressive, use with caution)
#
# The module hard-caps this at 0.1 for safety. Leave blank to use default.
SIM_SPREAD_CENTS=0.01


# -------- Crypto deposits (REQUIRED for deposit flow) --------
# HD wallet extended PUBLIC key. Do NOT paste your seed or xprv here.
# Generate an HD wallet offline (BIP39), export the xpub at path m/44'/60'/0'/0,
# and paste the extended public key here.
#
# Private keys remain in cold storage. This server only derives addresses.
HOT_WALLET_XPUB=

# Base mainnet RPC URL. Use Alchemy, QuickNode, or Infura for production.
# Public endpoint works for low volume but will rate-limit.
BASE_RPC_URL=https://mainnet.base.org

# SAFETY FLAG: set to "true" only when legally cleared to credit real deposits.
# When false (default), the indexer detects and stores deposits but does
# NOT credit user balances. Useful for verifying the pipeline on mainnet.
CRYPTO_DEPOSITS_LIVE=false
